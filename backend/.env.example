PORT=3000
NODE_ENV=development
ALLOW_LOCAL_AUTH=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
GEMINI_API_KEY=
# gemini-2.0-flash supports vision for lecture photo text extraction on upload
GEMINI_MODEL=gemini-2.0-flash

# OCR pipeline: Tesseract first, Gemini Vision fallback
TESSERACT_OCR=true
TESSERACT_MIN_CONFIDENCE=0.42
TESSERACT_MIN_CHARS=20
VISION_OCR_MIN_CONFIDENCE=0.35
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRICE_LABEL=$10/month
STRIPE_MODE=subscription
STRIPE_SUCCESS_URL=
